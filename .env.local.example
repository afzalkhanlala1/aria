# =============================================================================
# Copy this file to `.env.local` (same folder) and fill in your real values.
# `.env.local` is gitignored — your key never leaves your machine.
# After editing, restart `npm run dev`.
# =============================================================================

# --- OpenAI ------------------------------------------------------------------
# Required for the Ask Aria sandbox + URL-scrape custom demos + voice TTS gen.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-replace-me

# Optional: override the chat model (default: gpt-4o-mini, cheap + fast).
# OPENAI_CHAT_MODEL=gpt-4o-mini

# Optional: override the TTS model used by `npm run voice:generate`.
# OPENAI_TTS_MODEL=gpt-4o-mini-tts

# --- Resend (audit form delivery) -------------------------------------------
# Required for the audit form to actually email leads. Get a free key at
# https://resend.com (3000 emails/mo free tier).
RESEND_API_KEY=re_replace-me

# Address audit-form emails come FROM. Must be a verified domain in Resend, or
# leave the default `onboarding@resend.dev` while testing.
RESEND_FROM="Aria <onboarding@resend.dev>"

# Where lead notifications go (the founder's inbox).
LEAD_NOTIFICATION_EMAIL=ariapersonalagent@gmail.com

# --- Cal.com (audit booking) -------------------------------------------------
# Your Cal.com link path, e.g. "yourhandle/15min". Create one free at
# https://cal.com — the inline embed on /audit will read this.
NEXT_PUBLIC_CAL_LINK=ariapersonalagent/15min

# --- Site --------------------------------------------------------------------
# Used by SEO / sitemap / OG image absolute URLs.
NEXT_PUBLIC_SITE_URL=https://aria.work
